# --- Postgres ---
# Host-side ports shifted from defaults to avoid collisions with other local stacks.
# Internal container ports stay standard (5432, 6379, 8000) — only host mapping moves.
POSTGRES_USER=processscout
POSTGRES_PASSWORD=change-me-in-real-deployments
POSTGRES_DB=processscout
POSTGRES_PORT=5532

# --- Redis ---
REDIS_PORT=6479

# --- Backend ---
BACKEND_PORT=8800
SECRET_KEY=generate-a-32-byte-random-string-here
ENVIRONMENT=development

# --- LLM ---
# Required to ask new questions; not required for browsing seeded data
OPENROUTER_API_KEY=

# --- Cost limits (USD, hard caps before any LLM dispatch) ---
COST_LIMIT_PER_DAY_USD=5
COST_LIMIT_PER_MONTH_USD=50

# --- Tracing (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Bootstrap superadmin (created on first boot if absent) ---
SUPERADMIN_EMAIL=admin@process-scout.com
SUPERADMIN_PASSWORD=change-me-on-first-login

# --- Frontend ---
FRONTEND_PORT=5273
